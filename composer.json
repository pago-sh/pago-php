{
    "name": "pago-sh/sdk",
    "description": "Pago SDK — A billing platform for the intelligence era",
    "type": "library",
    "license": "MIT",
    "keywords": ["pago", "sdk", "api", "billing", "payments"],
    "homepage": "https://pago.sh",
    "support": {
        "issues": "https://github.com/pago-sh/pago/issues",
        "source": "https://github.com/pago-sh/pago"
    },
    "authors": [
        {
            "name": "Pago",
            "homepage": "https://pago.sh"
        }
    ],
    "require": {
        "php": ">=8.2",
        "ext-json": "*",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.1 || ^2.0",
        "php-http/discovery": "^1.19"
    },
    "require-dev": {
        "nyholm/psr7": "^1.8",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Pago\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Pago\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": "phpstan analyse --no-progress --memory-limit=4G",
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}